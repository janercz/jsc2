@model Shelter
@{ ViewData["Title"] = Model.Name; }

<div class="bg-white p-8 rounded-lg shadow-md mb-8 border-t-8 border-gray-800">
    <h1 class="text-4xl font-bold mb-4 text-red-700">@Model.Name</h1>
    <p class="text-lg text-gray-700 mb-2"><strong>Lokace:</strong> @Model.Location</p>
    <p class="text-lg text-gray-700 mb-2"><strong>Kapacita:</strong> @Model.Capacity psů</p>
    <p class="text-gray-600 mt-4 bg-gray-100 p-4 rounded">@Model.Description</p>
</div>

<div class="flex justify-between items-center mb-6 border-b-2 border-gray-300 pb-2">
    <h2 class="text-3xl font-bold text-gray-800">K adopci</h2>
    <a asp-controller="Dog" asp-action="Create" asp-route-shelterId="@Model.Id" 
       class="bg-gray-800 hover:bg-gray-900 text-white px-6 py-2 rounded font-bold shadow-md transition">
        + Přidat psa
    </a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    @if(Model.Dogs.Any())
    {
        @foreach (var dog in Model.Dogs)
        {
            <div class="bg-white p-5 rounded-lg shadow border border-gray-200 hover:border-red-500 transition">
                <h3 class="text-xl font-bold text-red-800 mb-1">@dog.Name</h3>
                <p class="text-sm text-gray-600 mb-4 font-medium">@dog.Breed, @dog.Age let</p>
                <a asp-controller="Dog" asp-action="Detail" asp-route-id="@dog.Id" 
                   class="block text-center bg-red-50 text-red-700 hover:bg-red-600 hover:text-white py-2 rounded font-semibold transition">
                   Detail psa
                </a>
            </div>
        }
    }
    else
    {
        <p class="text-gray-500 col-span-full italic">Tento útulek aktuálně nemá žádné psy k adopci.</p>
    }
</div>