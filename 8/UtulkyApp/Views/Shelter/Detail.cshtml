@model Shelter
@{ ViewData["Title"] = Model.Name; }

<div class="card-soft p-8 mb-8 border-t-4 border-brand-500">
    <h1 class="page-title mb-3">@Model.Name</h1>
    <p class="text-lg text-ink-700 mb-2"><strong>Lokace:</strong> @Model.Location</p>
    <p class="text-lg text-ink-700 mb-2"><strong>Kapacita:</strong> @Model.Capacity psů</p>
    <p class="text-ink-700 mt-4 bg-brand-50 p-4 rounded-xl border border-brand-100">@Model.Description</p>
</div>

<div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3 mb-6 border-b border-brand-100 pb-3">
    <h2 class="section-title">K adopci</h2>
    <a asp-controller="Dog" asp-action="Create" asp-route-shelterId="@Model.Id" 
       class="btn-primary text-center">
        + Přidat psa
    </a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    @if(Model.Dogs.Any())
    {
        @foreach (var dog in Model.Dogs)
        {
            <div class="card-soft p-5 hover:shadow-soft transition-shadow duration-300">
                <h3 class="text-xl font-bold text-brand-700 mb-1">@dog.Name</h3>
                <p class="text-sm text-ink-700 mb-4 font-medium">@dog.Breed, @dog.Age let</p>
                <a asp-controller="Dog" asp-action="Detail" asp-route-id="@dog.Id" 
                   class="block text-center bg-brand-50 text-brand-700 hover:bg-brand-500 hover:text-white py-2 rounded-xl font-semibold transition">
                   Detail psa
                </a>
            </div>
        }
    }
    else
    {
        <p class="text-ink-700/70 col-span-full italic">Tento útulek aktuálně nemá žádné psy k adopci.</p>
    }
</div>