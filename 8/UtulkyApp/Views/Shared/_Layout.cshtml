<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Útulky Vlček</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-200 min-h-screen flex flex-col">
    <header class="bg-red-700 text-white shadow-md border-b-4 border-red-900">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <a asp-controller="Home" asp-action="Index" class="text-2xl font-bold tracking-wider">Zvířecí Útulky</a>
            
            <form asp-controller="Dog" asp-action="Search" method="get" class="flex gap-2">
                <input type="text" name="query" placeholder="Hledat psa..." class="px-4 py-2 rounded text-black outline-none border border-gray-300 focus:ring-2 focus:ring-red-500" required>
                <button type="submit" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded font-semibold transition">Hledat</button>
            </form>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8 flex-grow">
        @RenderBody()
    </main>

    <footer class="bg-gray-900 text-gray-400 text-center py-4 mt-auto border-t-2 border-red-800">
        <p>&copy; @DateTime.Now.Year - Útulky Vlček</p>
    </footer>
</body>
</html>