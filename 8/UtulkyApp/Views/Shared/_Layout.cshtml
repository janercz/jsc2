<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Útulky</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=Source+Serif+4:opsz,wght@8..60,500;8..60,700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: "#f5fbf9",
                            100: "#d9efe7",
                            500: "#1f8f72",
                            600: "#18725b",
                            700: "#125a48",
                            900: "#0b3a30"
                        },
                        accent: {
                            500: "#c1663f",
                            600: "#a75534"
                        },
                        ink: {
                            700: "#2f3b47",
                            900: "#16212b"
                        }
                    },
                    boxShadow: {
                        card: "0 16px 40px rgba(22, 33, 43, 0.10)",
                        soft: "0 10px 24px rgba(17, 24, 39, 0.08)"
                    }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col app-body text-ink-900">
    <div class="background-orb background-orb-one"></div>
    <div class="background-orb background-orb-two"></div>

    <header class="sticky top-0 z-30 border-b border-white/60 bg-white/85 backdrop-blur">
        <div class="container mx-auto px-4 py-4 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-center justify-between">
                <a asp-controller="Home" asp-action="Index" class="text-2xl tracking-tight brand-title text-brand-900">Útulky</a>
            </div>

            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-end w-full lg:w-auto">
                <nav class="flex items-center gap-2 md:gap-4 text-sm font-semibold text-ink-700">
                    <a asp-controller="Home" asp-action="Index" class="nav-link">Útulky</a>
                </nav>

                <form asp-controller="Dog" asp-action="Search" method="get" class="flex gap-2 items-center">
                    <input type="text" name="query" placeholder="Hledat podle jména psa" class="search-input" required>
                    <button type="submit" class="btn-primary">Hledat</button>
                </form>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8 md:py-10 flex-grow w-full">
        <div class="content-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-auto border-t border-brand-100 bg-white/80 backdrop-blur-sm">
        <div class="container mx-auto px-4 py-5 text-sm text-ink-700 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <p>&copy; @DateTime.Now.Year - Útulky</p>
            <p class="text-ink-700/70">Katalog útulků a adopcí</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>