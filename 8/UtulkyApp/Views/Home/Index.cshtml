@model IEnumerable<Shelter>
@{ ViewData["Title"] = "Seznam útulků"; }

<div class="mb-8">
    <h1 class="page-title mb-2">Dostupné útulky</h1>
    <p class="text-ink-700">Vyberte útulek a objevte pejsky, kteří čekají na nový domov.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var s in Model)
    {
        <div class="card-soft p-6 hover:shadow-card transition-shadow duration-300">
            <h2 class="text-2xl font-bold text-ink-900 mb-2">@s.Name</h2>
            <p class="text-ink-700 mb-4 font-medium">Lokalita: @s.Location</p>
            <a asp-controller="Shelter" asp-action="Detail" asp-route-id="@s.Id" 
               class="inline-flex items-center gap-2 font-semibold text-brand-700 hover:text-brand-900 transition-colors">
               Zobrazit detail <span aria-hidden="true">&rarr;</span>
            </a>
        </div>
    }
</div>