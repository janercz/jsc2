@model IEnumerable<UtulkyApp.Models.Dog>
@{ ViewData["Title"] = "Výsledky hledání"; }

<h1 class="page-title mb-6">Výsledky hledání pro: "@ViewBag.Query"</h1>

@if (!Model.Any())
{
    <p class="text-accent-600 bg-accent-500/10 p-4 rounded-xl border border-accent-500/30">Bohužel jsme žádného pejska s tímto jménem nenašli.</p>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @foreach (var dog in Model)
        {
            <div class="card-soft p-5">
                <h3 class="font-bold text-2xl mb-1 text-ink-900">@dog.Name</h3>
                <p class="text-sm text-ink-700 mb-2">Rasa: @dog.Breed | Věk: @dog.Age</p>
                <p class="mb-4 text-ink-700">@dog.Description</p>
                
                @if(dog.Shelter != null)
                {
                    <div class="mt-4 p-3 bg-brand-50 border border-brand-100 rounded-xl text-sm flex justify-between items-center gap-2">
                        <span>Tento pejsek čeká v útulku <strong>@dog.Shelter.Name</strong></span>
                        <a asp-controller="Shelter" asp-action="Detail" asp-route-id="@dog.ShelterId" class="text-brand-700 hover:text-brand-900 font-bold whitespace-nowrap">Přejít do útulku &rarr;</a>
                    </div>
                }
            </div>
        }
    </div>
}