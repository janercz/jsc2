@model Dog
@{ ViewData["Title"] = "Přidat psa"; }

<div class="max-w-2xl mx-auto card-soft p-8">
    <h1 class="page-title mb-6">Přidat nového psa</h1>

    <form asp-action="Create" method="post" class="space-y-4">
        <input type="hidden" asp-for="ShelterId" value="@ViewBag.ShelterId" />

        <div>
            <label asp-for="Name" class="block text-ink-700 font-semibold mb-1">Jméno psa</label>
            <input asp-for="Name" class="w-full border border-brand-100 px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-500" required />
        </div>

        <div>
            <label asp-for="Breed" class="block text-ink-700 font-semibold mb-1">Rasa</label>
            <input asp-for="Breed" class="w-full border border-brand-100 px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-500" required />
        </div>

        <div>
            <label asp-for="Age" class="block text-ink-700 font-semibold mb-1">Věk (roky)</label>
            <input asp-for="Age" type="number" class="w-full border border-brand-100 px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-500" required />
        </div>

        <div>
            <label asp-for="Description" class="block text-ink-700 font-semibold mb-1">Popis povahy</label>
            <textarea asp-for="Description" rows="4" class="w-full border border-brand-100 px-4 py-2 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
        </div>

        <button type="submit" class="w-full btn-primary py-3">
            Přidat
        </button>
    </form>
</div>