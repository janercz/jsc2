@model IEnumerable<Dog>
@{ ViewData["Title"] = "Výsledky hledání"; }

<h1 class="page-title mb-6">Výsledky hledání pro: "@ViewBag.Query"</h1>

@if (Model.Any())
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var dog in Model)
        {
            <div class="card-soft p-6 border-l-4 border-accent-500">
                <h3 class="text-2xl font-bold mb-1 text-ink-900">@dog.Name</h3>
                <p class="text-ink-700 mb-3">@dog.Breed, @dog.Age let</p>
                <div class="flex flex-col gap-2">
                    <a asp-controller="Dog" asp-action="Detail" asp-route-id="@dog.Id" class="text-brand-700 font-semibold hover:text-brand-900">Detail psa</a>
                    <a asp-controller="Shelter" asp-action="Detail" asp-route-id="@dog.ShelterId" class="text-sm text-ink-700/80 hover:text-ink-900">Zobrazit útulek: @dog.Shelter?.Name</a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="bg-accent-500/10 text-accent-600 p-4 rounded-xl border border-accent-500/30">
        Bohužel jsme nenašli žádného psa se jménem obsahujícím "@ViewBag.Query".
    </div>
}