@model IEnumerable<Dog>
@{ ViewData["Title"] = "Výsledky hledání"; }

<h1 class="text-3xl font-bold mb-6 text-gray-800">Výsledky hledání pro: "@ViewBag.Query"</h1>

@if (Model.Any())
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var dog in Model)
        {
            <div class="bg-white p-6 rounded shadow border-l-4 border-orange-500">
                <h3 class="text-2xl font-bold mb-1">@dog.Name</h3>
                <p class="text-gray-600 mb-3">@dog.Breed, @dog.Age let</p>
                <div class="flex flex-col gap-2">
                    <a asp-controller="Dog" asp-action="Detail" asp-route-id="@dog.Id" class="text-blue-600 font-semibold hover:underline">Detail psa</a>
                    <a asp-controller="Shelter" asp-action="Detail" asp-route-id="@dog.ShelterId" class="text-sm text-gray-500 hover:text-gray-800">Zobrazit útulek: @dog.Shelter?.Name</a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="bg-yellow-50 text-yellow-800 p-4 rounded">
        Bohužel jsme nenašli žádného psa se jménem obsahujícím "@ViewBag.Query".
    </div>
}